{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patrici.us/schemas/source_registry.schema.json",
  "title": "Source Registry",
  "type": "object",
  "required": ["schema_version", "generated_at", "sources"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "url",
          "retrieved_at",
          "checksum",
          "doc_type",
          "license_note",
          "storage_uri"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^src_[0-9]{4}$"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "checksum": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "doc_type": {
            "type": "string",
            "enum": ["PDF", "XLSX"]
          },
          "license_note": {
            "type": "string",
            "minLength": 1
          },
          "storage_uri": {
            "type": "string",
            "pattern": "^s3://"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
